# =============================================================================
# Strict .gitignore for paper repository — public visibility, paranoid hygiene
# =============================================================================
# Order: secrets first (most critical), then bulk artifacts, then platform noise.

# ----- Secrets, credentials, keys (NEVER COMMIT) -----
.env
.env.*
!.env.example
*.env
secrets/
secrets.*
credentials*
*.pem
*.key
*.p12
*_rsa
*_rsa.pub
*_dsa
*_dsa.pub
*_ecdsa
*_ecdsa.pub
*_ed25519
*_ed25519.pub
id_rsa*
id_dsa*
id_ed25519*
known_hosts
authorized_keys
*api_key*
*api-key*
*apikey*
.netrc
.pypirc
.npmrc
.pgpass
google-credentials*.json
*service-account*.json
firebase-adminsdk-*.json
*.pem.txt
api_keys.txt
config.local.*
config.private.*

# ----- AI tooling outputs that should not be public -----
.claude/
.aider*
.cursorignore
.cursor/
.windsurfrules

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
pip-log.txt
pip-delete-this-directory.txt
.eggs/
*.egg-info/
*.egg
build/
dist/
develop-eggs/
downloads/
parts/
sdist/
wheels/
share/python-wheels/
.installed.cfg
MANIFEST

# ----- Node -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store/
.npm/

# ----- Jupyter -----
.ipynb_checkpoints/
*.ipynb_checkpoints

# ----- LaTeX intermediates (KEEP .tex source, drop build artifacts) -----
*.aux
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.ilg
*.ind
*.idx
*.lof
*.log
*.lot
*.nav
*.out
*.run.xml
*.snm
*.synctex.gz
*.synctex(busy)
*.toc
*.vrb
*.xdv
*.dvi

# ----- Editor / IDE -----
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
Thumbs.db
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ----- Logs & temp -----
*.log
logs/
*.tmp
*.temp
.cache/
tmp/
temp/

# ----- Large/derived artifacts that should NOT be in a paper repo -----
*.ckpt
*.pth
*.pt
*.bin
*.h5
*.onnx
*.tflite
*.gguf
wandb/

# Large arXiv submission tarballs — keep the source, regenerate when needed
*-arxiv.tar.gz
*-submission.tar.gz

# ----- Misc -----
*.bak
*.orig
*.rej
.git-rewrite/
